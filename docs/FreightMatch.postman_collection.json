								}
							],
							"body": "[\n  {\n    \"_id\": \"665a1b2c3d4e5f6789012346\",\n    \"email\": \"carrier@freightmatch.com\",\n    \"role\": \"Carrier\",\n    \"carrierProfile\": {\n      \"truckType\": \"refrigerated\",\n      \"capacityKg\": 18000,\n      \"homeCity\": \"Istanbul\",\n      \"rating\": 0,\n      \"completedShipments\": 0\n    }\n  }\n]"
