{
	"info": {
		"_postman_id": "freightmatch-collection-2026",
		"name": "FreightMatch",
		"description": "Complete API collection for the FreightMatch freight-matching platform.\n\n**Setup:**\n1. Run requests in order — Register → Login → then the rest\n2. Login scripts auto-save tokens AND user IDs\n3. Create Load / Create Bid scripts auto-save the created resource IDs\n4. Every request uses the correct dynamic variables — no manual copy-paste needed\n\n**Roles:**\n- **Shipper**: Create/manage loads, view/accept bids\n- **Carrier**: View available loads, place bids, manage carrier profile\n\n**Base URL:** `http://localhost:80` (Nginx gateway)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:80",
			"type": "string"
		},
		{
			"key": "shipperAuthToken",
			"value": "(auto-filled after Shipper login)",
			"type": "string"
		},
		{
			"key": "carrierAuthToken",
			"value": "(auto-filled after Carrier login)",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "(auto-filled after login)",
			"type": "string"
		},
		{
			"key": "shipperId",
			"value": "(auto-filled after Shipper login)",
			"type": "string"
		},
		{
			"key": "carrierId",
			"value": "(auto-filled after Carrier login)",
			"type": "string"
		},
		{
			"key": "loadId",
			"value": "(auto-filled after Create Load)",
			"type": "string"
		},
		{
			"key": "bidId",
			"value": "(auto-filled after Create Bid)",
			"type": "string"
		},
		{
			"key": "draftLoadId",
			"value": "(auto-filled after Create Draft Load)",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "User Service",
			"description": "Handles user registration, authentication, token refresh, profile retrieval, and carrier profile management.",
			"item": [
				{
					"name": "Register Shipper",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"register"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"shipper@freightmatch.com\",\n  \"password\": \"Shipper123!\",\n  \"role\": \"Shipper\"\n}"
						},
						"description": "Register a new user with the **Shipper** role."
					},
					"response": [
						{
							"name": "201 Created",
							"status": "Created",
							"code": 201,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"id\": \"665a1b2c3d4e5f6789012345\",\n  \"email\": \"shipper@freightmatch.com\",\n  \"role\": \"Shipper\",\n  \"createdAt\": \"2026-03-09T10:00:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Register Carrier",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"register"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"carrier@freightmatch.com\",\n  \"password\": \"Carrier123!\",\n  \"role\": \"Carrier\"\n}"
						},
						"description": "Register a new user with the **Carrier** role."
					},
					"response": [
						{
							"name": "201 Created",
							"status": "Created",
							"code": 201,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"id\": \"665a1b2c3d4e5f6789012346\",\n  \"email\": \"carrier@freightmatch.com\",\n  \"role\": \"Carrier\",\n  \"createdAt\": \"2026-03-09T10:01:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Login Shipper",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const res = pm.response.json();",
									"    pm.collectionVariables.set('shipperAuthToken', res.accessToken);",
									"    pm.collectionVariables.set('refreshToken', res.refreshToken);",
									"    pm.collectionVariables.set('shipperId', res.user.id);",
									"    console.log('✅ Shipper token + ID saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"login"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"shipper@freightmatch.com\",\n  \"password\": \"Shipper123!\"\n}"
						},
						"description": "Login as a **Shipper**. Auto-saves `shipperAuthToken`, `refreshToken`, and `shipperId`."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"665a1b2c3d4e5f6789012345\",\n    \"email\": \"shipper@freightmatch.com\",\n    \"role\": \"Shipper\"\n  }\n}"
						}
					]
				},
				{
					"name": "Login Carrier",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const res = pm.response.json();",
									"    pm.collectionVariables.set('carrierAuthToken', res.accessToken);",
									"    pm.collectionVariables.set('refreshToken', res.refreshToken);",
									"    pm.collectionVariables.set('carrierId', res.user.id);",
									"    console.log('✅ Carrier token + ID saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"login"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"carrier@freightmatch.com\",\n  \"password\": \"Carrier123!\"\n}"
						},
						"description": "Login as a **Carrier**. Auto-saves `carrierAuthToken`, `refreshToken`, and `carrierId`."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": \"665a1b2c3d4e5f6789012346\",\n    \"email\": \"carrier@freightmatch.com\",\n    \"role\": \"Carrier\"\n  }\n}"
						}
					]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/refresh",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"refresh"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"description": "Exchange a valid refresh token for a new access token."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
						}
					]
				},
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{shipperAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/profile",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"profile"
							]
						},
						"description": "Get the authenticated user's own profile. Uses `shipperAuthToken` — swap to `carrierAuthToken` for carrier profile."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"_id\": \"665a1b2c3d4e5f6789012345\",\n  \"email\": \"shipper@freightmatch.com\",\n  \"role\": \"Shipper\",\n  \"createdAt\": \"2026-03-09T10:00:00.000Z\",\n  \"updatedAt\": \"2026-03-09T10:00:00.000Z\"\n}"
						}
					]
				},
				{
					"name": "Get User by ID",
					"request": {
						"method": "GET",
						"header": [
							{
