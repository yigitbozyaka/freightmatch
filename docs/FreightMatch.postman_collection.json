							]
						},
						"description": "Get a user by ID. Uses `{{carrierId}}` (auto-filled from Carrier login). Swap to `{{shipperId}}` to look up the shipper."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"_id\": \"665a1b2c3d4e5f6789012346\",\n  \"email\": \"carrier@freightmatch.com\",\n  \"role\": \"Carrier\",\n  \"createdAt\": \"2026-03-09T10:01:00.000Z\",\n  \"updatedAt\": \"2026-03-09T10:01:00.000Z\"\n}"
						}
					]
				},
				{
