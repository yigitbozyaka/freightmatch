		},
		{
			"name": "Load Service",
			"description": "Manages freight loads — creation, retrieval, updates, deletion, status transitions, and carrier-facing available load listings.",
			"item": [
				{
					"name": "Create Load",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    const res = pm.response.json();",
									"    pm.collectionVariables.set('loadId', res._id);",
									"    console.log('✅ loadId saved: ' + res._id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{shipperAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/loads",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"loads"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Refrigerated Dairy Products - Istanbul to Ankara\",\n  \"origin\": \"Istanbul\",\n  \"destination\": \"Ankara\",\n  \"cargoType\": \"Perishable Goods\",\n  \"weightKg\": 12000,\n  \"deadlineHours\": 24\n}"
						},
						"description": "Create a new load. **Shipper role required.** Auto-saves `loadId`."
					},
					"response": [
						{
							"name": "201 Created",
							"status": "Created",
							"code": 201,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"_id\": \"665b2c3d4e5f67890123abcd\",\n  \"shipperId\": \"665a1b2c3d4e5f6789012345\",\n  \"title\": \"Refrigerated Dairy Products - Istanbul to Ankara\",\n  \"origin\": \"Istanbul\",\n  \"destination\": \"Ankara\",\n  \"cargoType\": \"Perishable Goods\",\n  \"weightKg\": 12000,\n  \"deadlineHours\": 24,\n  \"status\": \"Draft\"\n}"
						}
					]
				},
