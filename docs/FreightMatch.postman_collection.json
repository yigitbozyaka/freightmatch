								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{shipperAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/loads/{{loadId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"loads",
								"{{loadId}}"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated - Refrigerated Dairy Products Istanbul to Izmir\",\n  \"destination\": \"Izmir\",\n  \"weightKg\": 15000\n}"
