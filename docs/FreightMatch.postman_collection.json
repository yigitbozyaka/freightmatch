					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"_id\": \"665b2c3d4e5f67890123abcd\",\n  \"title\": \"Updated - Refrigerated Dairy Products Istanbul to Izmir\",\n  \"destination\": \"Izmir\",\n  \"weightKg\": 15000\n}"
						}
					]
				},
				{
					"name": "Update Load Status",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{shipperAuthToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/loads/{{loadId}}/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"loads",
								"{{loadId}}",
								"status"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"Posted\"\n}"
						},
						"description": "Transition load status. **Shipper role required.** Uses `{{loadId}}`. Valid: Draft→Posted→Matched→InTransit→Delivered."
					},
					"response": [
						{
							"name": "200 OK",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
